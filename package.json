{
  "name": "spotify-playlist-thing",
  "version": "1.0.0",
  "description": "Auto-categorise Spotify Liked Songs into playlists using LLM classification",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sync": "tsx src/sync.ts",
    "bootstrap": "tsx src/auth-bootstrap.ts",
    "typecheck": "tsc --noEmit",
    "dry-run": "tsx src/sync.ts --dry-run"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "dotenv": "^17.4.2",
    "essentia.js": "^0.1.3",
    "openai": "^4.77.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
