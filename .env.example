# Spotify OAuth credentials.
# Create a Spotify developer app at https://developer.spotify.com/dashboard
# and note the Client ID and Client Secret shown in the app settings.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Spotify OAuth refresh token.
# Obtained by running `pnpm bootstrap` once locally. The script opens a browser,
# you log in with your Spotify account, and it prints a long-lived refresh token.
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# Last.fm API key.
# Free and instant — create one at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here

# OpenRouter API key.
# Sign up at https://openrouter.ai, load $5 credit (will last years at this usage).
# Used to route classification calls to Gemini / other cheap models.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# MusicBrainz contact email.
# Required by the MusicBrainz API in the User-Agent header per their policy:
# https://musicbrainz.org/doc/MusicBrainz_API/Rate_Limiting
# Use your own email address so they can contact you if there's an issue.
MUSICBRAINZ_CONTACT_EMAIL=your_email@example.com
